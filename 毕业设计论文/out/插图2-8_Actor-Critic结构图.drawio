                    <mxGeometry x="100" y="380" width="420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec_critic" value="Critic 支路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=20;fontStyle=1;fontColor=#1d4ed8;" parent="1" vertex="1">
                    <mxGeometry x="905" y="380" width="420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="input1" value="观测输入 obs&#xa;Tracking 任务中包含：&#xa;末端状态、物体状态、底盘状态、机械臂状态等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="530" y="160" width="420" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="input2" value="RunningMeanStd 标准化&#xa;先对观测做归一化，再送入网络" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="530" y="295" width="420" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="split" value="共享输入&#xa;分成两条支路" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=19;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="620" y="405" width="240" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="actor1" value="Actor MLP&#xa;当前项目默认结构：&#xa;Linear -&gt; ELU -&gt; Linear -&gt; ELU&#xa;隐藏层规模如 [256, 128]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="120" y="530" width="380" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="actor3" value="&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;动作均值 mu，&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;输出每个动作维度的均值。&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;动作方差参数 sigma，由可学习参数控制&lt;br&gt;与 mu 一起确定高斯动作分布" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="115" y="710" width="390" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="actor4" value="构造动作分布 Normal(mu, sigma)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#16a34a;fontSize=19;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="120" y="870" width="380" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="actor5" value="采样动作 actions&#xa;并计算 neglogp / entropy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#16a34a;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="120" y="980" width="380" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="critic1" value="Critic MLP&lt;br&gt;当前项目可与 Actor 结构相同，&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="930" y="550" width="360" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="critic2" value="值函数头 value&#xa;Linear(hidden, 1)&#xa;输出当前状态的 V(s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="920" y="760" width="380" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="critic3" value="Critic 输出 value_preds，&lt;br&gt;训练时要去拟合 return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="920" y="948" width="380" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="merge1" value="Actor 输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="190" y="1126" width="240" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="merge2" value="Critic 输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="990" y="1126" width="240" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="merge3" value="送入 PPO 训练" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="575" y="1210" width="330" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="ppo1" value="Actor 参与策略更新&lt;br&gt;使用 actions、old_neglogp、new_neglogp、advantage，计算 clipped policy loss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1290" width="430" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="ppo2" value="Critic 参与价值拟合&lt;br&gt;使用 value_preds 与 return，计算 critic loss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=19;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="920" y="1290" width="430" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="note1" value="当前项目特点&#xa;Actor 输出的是连续动作高斯分布参数，而不是离散动作概率。&#xa;因此使用 mu 与 sigma 来表示策略。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cbd5e1;fontSize=18;align=left;spacingTop=8;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="100" y="1420" width="450" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="note2" value="当前项目特点&#xa;Critic 预测的是状态价值 V(s)，不是动作价值 Q(s,a)。&#xa;训练时通过 return 去监督 value 逼近未来回报。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cbd5e1;fontSize=18;align=left;spacingTop=8;spacingLeft=12;" parent="1" vertex="1">
