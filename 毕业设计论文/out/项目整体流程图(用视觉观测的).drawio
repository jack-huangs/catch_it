<mxfile host="app.diagrams.net" modified="2026-04-25T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="project-overall-vision" name="项目整体流程图(用视觉观测的)">
    <mxGraphModel dx="1800" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="2339" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="项目整体流程图（视觉观测版）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="470" y="10" width="660" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="基于当前项目实现：base 相机 RGB-D 感知目标，视觉状态送入 PPO，控制移动底盘与机械臂协同触碰来球" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontColor=#4b5563;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="1080" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="sec_env" value="仿真与感知层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=18;fontStyle=1;fontColor=#166534;" vertex="1" parent="1">
          <mxGeometry x="70" y="95" width="430" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="sec_policy" value="决策与控制层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=18;fontStyle=1;fontColor=#1d4ed8;" vertex="1" parent="1">
          <mxGeometry x="565" y="95" width="430" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="sec_train" value="训练监督层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=18;fontStyle=1;fontColor=#92400e;" vertex="1" parent="1">
          <mxGeometry x="1060" y="95" width="430" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="env1" value="1. MuJoCo / DcmmVecEnv 环境&#xa;包含 tidybot、目标物体、动力学、碰撞、随机抛球与回合管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="430" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="env2" value="2. base 相机渲染 RGB-D&#xa;render(&quot;rgb_array&quot;, camera=&quot;base&quot;)&#xa;render(&quot;depth_array&quot;, camera=&quot;base&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="430" height="102" as="geometry"/>
        </mxCell>
        <mxCell id="env3" value="3. 视觉状态估计&#xa;RGB-D -&gt; 红球检测 -&gt; 深度统计 -&gt; 反投影 -&gt; 3D 跟踪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="445" width="430" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="env4" value="4. 构造视觉物体状态&#xa;object.pos3d = visual pos3d&#xa;object.v_lin_3d = visual v_lin_3d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="585" width="430" height="96" as="geometry"/>
        </mxCell>
        <mxCell id="env5" value="5. 生成完整观测 obs&#xa;视觉物体状态 + 末端状态 + 底盘状态 + 机械臂状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="720" width="430" height="86" as="geometry"/>
        </mxCell>

        <mxCell id="pol1" value="6. RunningMeanStd 标准化观测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="565" y="220" width="430" height="58" as="geometry"/>
        </mxCell>
        <mxCell id="pol2" value="7. Actor-Critic 前向推理&#xa;输出 actions、values、neglogp、mu、sigma" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="565" y="320" width="430" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="pol3" value="8. 9 维动作发送到环境&#xa;底盘控制 + 7 关节机械臂 + 夹爪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="565" y="455" width="430" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="pol4" value="9. 执行动作与物理仿真&#xa;PID / 运动学 / MuJoCo step 更新底盘、机械臂与目标物体状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="565" y="585" width="430" height="96" as="geometry"/>
        </mxCell>
        <mxCell id="pol5" value="10. 形成闭环&#xa;新状态再次被 base 相机观测，进入下一步决策" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="565" y="720" width="430" height="86" as="geometry"/>
        </mxCell>

        <mxCell id="tr1" value="11. 环境计算 reward 与 done&#xa;基于 ee_distance、base_distance、接触关系、成功阈值等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="220" width="430" height="88" as="geometry"/>
        </mxCell>
        <mxCell id="tr2" value="12. 写入 ExperienceBuffer&#xa;存储 obs、actions、values、neglogp、mu、sigma、rewards、dones" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="350" width="430" height="96" as="geometry"/>
        </mxCell>
        <mxCell id="tr3" value="13. rollout 结束后计算 GAE / return&#xa;根据 rewards、values、last_values 递推 advantage 与 return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="490" width="430" height="96" as="geometry"/>
        </mxCell>
        <mxCell id="tr4" value="14. PPO 更新网络&#xa;actor loss + critic loss - entropy + bounds loss&#xa;backward() -&gt; clip grad -&gt; optimizer.step()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="630" width="430" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="tr5" value="15. 更新后的策略进入下一轮采样&#xa;继续与视觉观测环境交互，直到达到 max_agent_steps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="785" width="430" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="mid1" value="当前正式视觉配置" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#94a3b8;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="890" width="520" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="mid2" value="use_visual_object_state = True&#xa;use_visual_object_velocity = True&#xa;camera_name = &quot;base&quot;&#xa;fallback_to_ground_truth = False" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cbd5e1;fontSize=17;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="970" width="520" height="112" as="geometry"/>
        </mxCell>
        <mxCell id="mid3" value="项目核心特点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="1120" width="520" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="mid4" value="策略输入来自视觉估计，而不是直接读取物体真值；&#xa;但 reward 与 success 仍由仿真环境计算，属于“视觉输入 + 仿真监督”的训练模式。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontSize=17;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="1200" width="620" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="mid5" value="最终目标" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="1340" width="520" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="mid6" value="让移动底盘与机械臂协同运动，控制夹爪末端触碰抛来的动态目标，&#xa;并为后续接入真实 RGB-D 相机与真机部署打基础。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="1420" width="620" height="94" as="geometry"/>
        </mxCell>

