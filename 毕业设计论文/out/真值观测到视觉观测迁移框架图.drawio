        </mxCell>
        <mxCell id="c6" value="把“直接读取物体真值”改造成“由视觉估计物体状态”&#xa;使策略输入形式更接近真实机器人部署场景" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1360" width="560" height="92" as="geometry"/>
        </mxCell>

