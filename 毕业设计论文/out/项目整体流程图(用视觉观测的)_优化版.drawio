<mxfile host="65bd71144e">
    <diagram id="project-overall-vision-v2" name="项目整体流程图(用视觉观测的)_优化版">
        <mxGraphModel dx="1360" dy="1192" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="2339" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;font style=&quot;font-size: 25px;&quot;&gt;项目整体流程图&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#111827;" parent="1" vertex="1">
                    <mxGeometry x="430" y="20" width="740" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="base 相机 RGB-D 观测目标，视觉状态送入 PPO，控制移动底盘与机械臂协同触碰抛来的目标物体" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontColor=#4b5563;" parent="1" vertex="1">
                    <mxGeometry x="290" y="60" width="1100" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="sec_main" value="主控制闭环" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=18;fontStyle=1;fontColor=#1d4ed8;" parent="1" vertex="1">
                    <mxGeometry x="330" y="90" width="620" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec_train" value="训练更新分支" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=18;fontStyle=1;fontColor=#92400e;" parent="1" vertex="1">
                    <mxGeometry x="980" y="220" width="360" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="b1" value="1. MuJoCo / DcmmVecEnv 环境&#xa;包含 tidybot、目标物体、动力学、碰撞、抛球与回合管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="150" width="430" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="b2" value="2. base 相机获取 RGB-D&#xa;render(&quot;rgb_array&quot;) + render(&quot;depth_array&quot;)&#xa;depth_2_meters() 转成米制深度" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="275" width="430" height="104" as="geometry"/>
                </mxCell>
                <mxCell id="b3" value="3. 视觉状态估计&#xa;红球检测 -&gt; 深度统计 -&gt; 反投影 -&gt; 3D 跟踪&#xa;得到 visual pos3d / visual v_lin_3d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="420" width="430" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="b4" value="4. 构造 PPO 观测 obs&#xa;视觉物体状态 + 末端状态 + 底盘状态 + 机械臂状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="570" width="430" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="b5" value="5. Actor-Critic 决策&#xa;RunningMeanStd 标准化后前向推理&#xa;输出 actions、values、neglogp、mu、sigma" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="700" width="430" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="b6" value="6. 输出 9 维动作&#xa;底盘控制 + 7 关节机械臂 + 夹爪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="850" width="430" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="2" style="edgeStyle=elbowEdgeStyle;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeWidth=2;" edge="1" parent="1" source="b7" target="t1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="b7" value="7. 环境执行动作&#xa;DcmmVecEnv.step() / MuJoCo 仿真推进&#xa;更新底盘、机械臂和目标物体状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="970" width="430" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="b8" value="8. 进入下一时刻&#xa;新状态再次被 base 相机观测，形成闭环" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=17;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="425" y="1120" width="430" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="t1" value="9. 计算 reward / done&#xa;基于 ee_distance、base_distance、接触关系、成功阈值等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=16;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="940" y="284" width="430" height="86" as="geometry"/>
                </mxCell>
                <mxCell id="t2" value="10. 写入 ExperienceBuffer&#xa;保存 obs、actions、values、neglogp、mu、sigma、rewards、dones" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=16;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="425" width="430" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="t3" value="11. rollout 结束后&#xa;计算 GAE advantage 与 return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=16;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="560" width="430" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="t4" value="12. PPO 更新网络&#xa;actor loss + critic loss - entropy + bounds loss&#xa;backward() -&gt; clip grad -&gt; optimizer.step()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=16;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="680" width="430" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="t5" value="13. 更新后的策略&#xa;进入下一轮采样与交互" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=16;fontStyle=1;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="852" width="430" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="note2" value="最终目标&lt;br&gt;让移动底盘与机械臂协同运动，控制夹爪末端触碰抛来的动态目标物体。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=16;align=left;spacingTop=8;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="590" y="1220" width="600" height="96" as="geometry"/>
                </mxCell>
