<mujoco model="gripper_camera_flipped_and_fixed">

    <option gravity="0 0 0"/>
    <compiler meshdir="assets/"/>

    <asset>
        <mesh name="gelsight_mini_mesh" file="gsmini_shell.stl" scale="0.001 0.001 0.001"/>
        
        <mesh name="gripper_connector_mesh" file="gripper_connector.stl" scale="1 1 1"/>

        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <visual>
        <global azimuth="90" elevation="-30"/>
    </visual>

    <worldbody>
        <light pos="0 0 10" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="2 2 0.05" type="plane" material="groundplane" pos="0 0 0.07"/>

        <body name="gripper_connector" pos="0.71 0.57 0.15" euler="90 0 0">
            <joint name="gripper_joint" type="slide" axis="0 0 1" range="-0.06 0"/>
            <geom type="mesh" mesh="gripper_connector_mesh" mass="0.5" rgba="0.2 0.2 0.2 1"/>

            <body name="gelsight_mini" pos="0.0272 0.017 0.015" euler="0 0 90">
                <geom name="gelsight_geom" type="mesh" mesh="gelsight_mini_mesh" mass="0.3"/>
                <camera name="gelsight_mini" mode="fixed" fovy="38" quat="1 1 0 0" pos="0.001 -0.01 0" />
            </body>
        </body>

        <body name="target_object" pos="0.712 0.555 0.165">

            <joint name="ball_x" type="slide" axis="1 0 0" damping="1.0" />
            <joint name="ball_y" type="slide" axis="0 1 0" damping="1.0" />
            <joint name="ball_z" type="slide" axis="0 0 1" damping="1.0" />
            
            <geom type="sphere" size="0.01" rgba="0.8 0.2 0.2 1"/>
        </body>
    </worldbody>

    <actuator>
        <position name="motor_x" joint="ball_x" kp="200" ctrlrange="-0.1 0.1"/>
        <position name="motor_y" joint="ball_y" kp="200" ctrlrange="-0.1 0.1"/>
        <position name="motor_z" joint="ball_z" kp="200" ctrlrange="-0.1 0.1"/>
    </actuator>
</mujoco>